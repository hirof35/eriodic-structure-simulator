<%# app/views/elements/index.html.erb %>

<header style="padding: 10px 20px; border-bottom: 1px solid #eee;">
  <h1 style="margin: 0; font-size: 1.5rem; color: #333;">
    構造科学的周期表シミュレーター <small style="font-size: 0.8rem; color: #888;">v1.0</small>
  </h1>
</header>

<div class="main-container" style="display: flex; gap: 20px; padding: 20px;">
  <div class="table-section" style="flex: 3;">
    <div class="filter-controls" style="margin-bottom: 15px;">
      </div>
    
    <div class="periodic-table">
      <% @elements.each do |element| %>
        <%= link_to element_path(element), data: { turbo_frame: "detail_panel" }, class: "element-link #{element.category_css_class}", style: "grid-column: #{element.xpos}; grid-row: #{element.ypos};" do %>
          <div class="element-card">
            <div class="atomic-number"><%= element.atomic_number %></div>
            <div class="symbol"><%= element.symbol %></div>
            <div class="name"><%= element.name %></div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>

  <aside class="side-panel" style="flex: 1;">
    <turbo-frame id="detail_panel">
      <div class="placeholder-message" style="text-align: center; color: #999; margin-top: 50px;">
        <p>元素を選択して構造を解析してください</p>
      </div>
    </turbo-frame>
  </aside>
</div>